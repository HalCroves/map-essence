   function getModelsByBrand($brand) {
       // Données statiques temporaires
       $models_data = [
           'Peugeot' => ['208', '308', '3008', '5008'],
           'Renault' => ['Clio', 'Megane', 'Captur', 'Kadjar'],
           'Citroën' => ['C3', 'C4', 'C5 Aircross'],
           'Volkswagen' => ['Golf', 'Polo', 'Tiguan'],
           'Ford' => ['Fiesta', 'Focus', 'Kuga'],
           'BMW' => ['Série 1', 'Série 3', 'X1', 'X3'],
           'Mercedes' => ['Classe A', 'Classe C', 'GLA'],
           'Audi' => ['A3', 'A4', 'Q3', 'Q5'],
           'Toyota' => ['Yaris', 'Corolla', 'RAV4'],
           'Honda' => ['Civic', 'CR-V', 'HR-V']
       ];
       
       return isset($models_data[$brand]) ? $models_data[$brand] : [];
   }
   
